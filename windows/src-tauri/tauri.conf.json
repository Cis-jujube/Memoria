{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Memoria",
  "version": "0.1.0",
  "identifier": "com.jujube.memoria.windows",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Memoria",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"]
  }
}
