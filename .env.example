# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/friend_memory?sslmode=require"

# Auth.js / NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-random-secret"
GOOGLE_CLIENT_ID="replace-with-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-oauth-client-secret"

# AI provider is optional for local UI/dev when AI_MOCK_FALLBACK is true.
# Use AI_PROVIDER="openai" or AI_PROVIDER="deepseek".
AI_PROVIDER="openai"

# OpenAI provider
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.5"

# DeepSeek provider. Uses OpenAI-compatible Chat Completions.
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-v4-flash"
DEEPSEEK_BASE_URL="https://api.deepseek.com"

AI_MOCK_FALLBACK="true"

# Vercel Blob
BLOB_READ_WRITE_TOKEN=""
UPLOAD_MAX_BYTES="10485760"
UPLOAD_MAX_REQUEST_BYTES="11534336"
UPLOAD_RATE_LIMIT_PER_HOUR="25"

# SendGrid reminder email
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="reminders@example.com"

# Vercel Cron protection
CRON_SECRET="replace-with-a-long-random-secret"
